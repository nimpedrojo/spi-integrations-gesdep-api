NODE_ENV=development
PORT=3000
LOG_LEVEL=info
GESDEP_BASE_URL=https://gesdep.net
GESDEP_HEADLESS=true
# Máximo de páginas de detalle abiertas en paralelo durante scraping batch
GESDEP_DETAIL_CONCURRENCY=6
# TTL de cache en memoria para /teams
CACHE_TTL_TEAMS_SECONDS=300
# TTL de cache en memoria para /teams/extended
CACHE_TTL_TEAMS_EXTENDED_SECONDS=1800
# TTL de cache en memoria para /players/:id
CACHE_TTL_PLAYER_SECONDS=3600
# Optional: set to a trusted Chrome/Edge executable to avoid corporate blocking
# GESDEP_CHROMIUM_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
GESDEP_USERNAME=your.user@example.com
GESDEP_PASSWORD=changeme
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=gesdep
DATABASE_PASSWORD=gesdep
DATABASE_NAME=gesdep
